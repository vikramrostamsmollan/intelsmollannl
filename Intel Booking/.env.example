# Google Calendar Integration — Intel Booking Platform
# Copy to .env and fill in values

# Account manager whose calendar receives booking events
ACCOUNT_MANAGER_EMAIL=accountmanager@intel.com

# Google Cloud OAuth 2.0 credentials
# Create at: https://console.cloud.google.com → APIs & Services → Credentials
# Type: Web application
GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_client_secret
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback

# Refresh token (obtained by running getAuthUrl() + exchangeCodeForTokens() once)
# The account manager must authorise the app via the URL before bookings work
GOOGLE_REFRESH_TOKEN=your_refresh_token

# Public URL for the booking platform (used in Calendar invite descriptions)
# Set to your Firebase Hosting URL after deployment
BOOKING_BASE_URL=https://intel-booking.web.app
